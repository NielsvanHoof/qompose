APP_NAME=Qompose
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single,sentry_logs

LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Data retention (days unless noted). Archived clients/dossiers are purged after archived_days.
RETENTION_ARCHIVED_DAYS=1095
RETENTION_ACTIVITY_LOG_DAYS=1095
RETENTION_FAILED_JOBS_HOURS=168
RETENTION_JOB_BATCHES_HOURS=48
RETENTION_NOTIFICATIONS_DAYS=90
RETENTION_PORTAL_GRANTS_DAYS=90

# Laravel Sail (PostgreSQL, Redis, Mailpit, MinIO)
DB_CONNECTION=pgsql
DB_HOST=pgsql
DB_PORT=5432
DB_DATABASE=laravel
DB_USERNAME=sail
DB_PASSWORD=password

# Scout database engine (pgsql). Tests override to "collection" for sqlite.
SCOUT_DRIVER=database

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_PATH=/
SESSION_DOMAIN=null
TRUSTED_PROXIES=REMOTE_ADDR

BROADCAST_CONNECTION=reverb

REVERB_APP_ID=local
REVERB_APP_KEY=local-reverb-key
REVERB_APP_SECRET=local-reverb-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Use `s3` with MinIO locally (see AWS_* below). Keep `local` for CI/tests without MinIO.
FILESYSTEM_DISK=local
FILESYSTEM_THROW=false
FILESYSTEM_REPORT=false
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_SCHEME=tcp
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

HEALTH_NOTIFICATIONS_ENABLED=false
# HEALTH_TO_ADDRESS=operations@example.com

# Require a recent password confirmation before staff view or download documents.
AUTH_DOCUMENT_ACCESS_TIMEOUT=900

# OCR: mock (default, offline) or textract (real AWS — see apps/platform/infra Pulumi stack)
OCR_DRIVER=mock

# Client portal sessions are created after redeeming a magic link.
PORTAL_SESSION_LIFETIME=15

# MinIO (Sail) — set FILESYSTEM_DISK=s3 and create private bucket `local` at http://localhost:8900
# For real Textract demos: FILESYSTEM_DISK=s3, clear AWS_ENDPOINT / AWS_URL, use Pulumi outputs.
AWS_ACCESS_KEY_ID=sail
AWS_SECRET_ACCESS_KEY=password
# Temporary STS token when assuming the Pulumi OCR operator role (leave empty for MinIO / long-lived keys).
# AWS_SESSION_TOKEN=
AWS_DEFAULT_REGION=eu-west-1
AWS_BUCKET=local
AWS_ENDPOINT=http://minio:9000
AWS_URL=http://localhost:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

# Textract (only when OCR_DRIVER=textract) — from `pulumi stack output` in apps/platform/infra
# TEXTRACT_SNS_TOPIC_ARN=
# TEXTRACT_SNS_ROLE_ARN=
# TEXTRACT_RESULTS_QUEUE_URL=
# TEXTRACT_SQS_MAX_RECEIVE_COUNT=5
# Assume OCR operator role for local AWS access:
#   (root cannot assume roles — use sync-ocr-credentials.sh instead)
#   apps/platform/infra/scripts/sync-ocr-credentials.sh
# Bedrock structures Textract LINE text (EU Claude Sonnet inference profile)
# OCR_BEDROCK_MODEL_ID=eu.anthropic.claude-sonnet-4-20250514-v1:0
# OCR_BEDROCK_REGION=eu-west-1
# OCR_BEDROCK_MAX_TOKENS=4096

VITE_APP_NAME="${APP_NAME}"

# Sail / Docker
WWWGROUP=1000
WWWUSER=1000
APP_PORT=80
VITE_PORT=5173
FORWARD_DB_PORT=5432
FORWARD_REDIS_PORT=6379
FORWARD_MAILPIT_PORT=1025
FORWARD_MAILPIT_DASHBOARD_PORT=8025
FORWARD_MINIO_PORT=9000
FORWARD_MINIO_CONSOLE_PORT=8900
FORWARD_REVERB_PORT=8080

SENTRY_ENABLE_LOGS=false
SENTRY_LARAVEL_DSN=
SENTRY_SEND_DEFAULT_PII=false
SENTRY_TRACES_SAMPLE_RATE=1.0
